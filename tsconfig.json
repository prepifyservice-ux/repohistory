{
    "compilerOptions": {
        "lib": ["es2021"],
        "module": "commonjs",
        "target": "es2021",
        "types": ["node"],
        "esModuleInterop": true,
        "outDir": "dist",
        "skipLibCheck": true,
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true
    },
    "exclude": ["node_modules", "dist"]
}